APP_NAME=KindredCare
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Toronto

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_CA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Laravel Telescope — local debug panel at /telescope. Set to false in
# production to skip all recording entirely (saves DB writes + the gate
# in TelescopeServiceProvider locks access by default anyway).
TELESCOPE_ENABLED=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kindredcare_v2
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

# Mail — `log` in dev so emails dump to storage/logs/laravel.log instead of
# spending Resend quota. In production switch MAIL_MAILER to `smtp` and fill
# the credentials below (Resend's SMTP relay; the API key is the password).
MAIL_MAILER=log
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="support@kindredcare.ca"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:3000

VERIFF_API_KEY=
VERIFF_SHARED_SECRET=

CERTN_CLIENT_ID=
CERTN_CLIENT_SECRET=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

MAPBOX_TOKEN=

VITE_APP_NAME="${APP_NAME}"
